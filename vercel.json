{
  "$schema": "https://openapi.vercel.com/vercel.json",
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build@1",
      "config": {
        "outputDirectory": "client/dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
